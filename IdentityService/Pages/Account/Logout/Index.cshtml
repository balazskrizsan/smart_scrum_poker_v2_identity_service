@page
@model IdentityService.Pages.Logout.Index

<div class="logout-page">
    <div class="lead">
        <h1>Logout</h1>
        <p>Would you like to logout of IdentityService?</p>
    </div>

    <form asp-page="/Account/Logout/Index">
        <input type="hidden" name="logoutId" value="@Model.LogoutId"  />
        
        <div class="form-group">
            <button type="submit" class="btn btn-primary" name="confirm" value="yes">Yes</button>
        </div>
    </form>
</div>
